APP_NAME=EasyNodeOne
BASE_DIR=/var/www/nodeone
LICENSE_PATH=/opt/nodeone/licenses
DATABASE_URL=
# SQLite por defecto si DATABASE_URL está vacío: instance/NodeOne.db bajo BASE_DIR
ENV=production
SECRET_KEY=
# URL pública (sin barra final); PayPal/OAuth/redirecciones
# URL canónica pública (OAuth/PayPal). Si usás solo app1: https://app1.easynodeone.com
BASE_URL=https://app1.easynodeone.com
# Checkout demo (Stripe/PayPal sin credenciales reales): si 1|true|yes, no auto-confirmar pago al crear intent (pending + banner en checkout para QA)
# NODEONE_CHECKOUT_NO_DEMO_AUTO_SUCCESS=1
# Yappy manual: tamaño máximo del comprobante en bytes (por defecto 5242880 = 5 MB; máx. 50 MB)
# YAPPY_RECEIPT_MAX_BYTES=5242880
# Formulario público de CV (/cv/registro): reCAPTCHA v2 «No soy un robot» (opcional; si falta, solo honeypot + servidor)
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
# Si 1: no registrar /admin/cv-applications ni descargas admin (solo formulario público /cv/registro)
# NODEONE_SKIP_CV_ADMIN_ROUTES=1
# apps.easynodeone.com y app1.easynodeone.com → mismo tenant que este slug (saas_organization.subdomain)
EASYNODEONE_APPS_ORG_SUBDOMAIN=tonysonax
# Nombres de organización legados a renombrar a "Easy Demo" (CSV, minúsculas)
LEGACY_SAAS_ORG_NAMES=
LOGO_BASENAME=logo-primary
# Capa de marca (opcional): preset IIUS o hex (sobrescriben Admin → Identidad)
# Preset iius: morado = botones (primary), marino = fondos (primary_dark), dorado = acento (accent)
# NODEONE_BRAND_PRESET=iius
# NODEONE_BRAND_PRIMARY=#8B60AA
# NODEONE_BRAND_PRIMARY_DARK=#00042D
# NODEONE_BRAND_ACCENT=#E6BF75
MAIL_DEFAULT_SENDER=noreply@example.com
# Office 365: 0|false|… apaga todo el despliegue. Por tenant: Admin → Módulos SaaS → office365
NODEONE_OFFICE365_MODULE_ENABLED=1
# Educación / LMS + Moodle: 0 apaga despliegue. NODEONE_SKIP_ACADEMIC_MODULE=1 no registra blueprints. Por tenant: Módulos SaaS → academic
NODEONE_ACADEMIC_MODULE_ENABLED=1
# Si 1: no encender automáticamente el módulo academic en orgs (dejar en off hasta Admin → Módulos)
# NODEONE_ACADEMIC_KEEP_DEFAULT_OFF=1
# Rol estudiante en Moodle (por defecto 5)
NODEONE_MOODLE_STUDENT_ROLE_ID=5
# Odoo (opcional)
ODOO_API_URL=
ODOO_WEBHOOK_SIGNATURE_HEADER=X-NodeOne-Signature

# PayPal — si Admin → Pagos tiene «variables de entorno» activo, estos valores mandan (live = api-m.paypal.com)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=
